# ===== FLAP API Keys (copy to .env and fill real values) =====

# Fast chat + audio transcription fallback (Groq Whisper)
GROQ_API_KEY=your_groq_api_key_here

# Long-context routing target (Mistral)
MISTRAL_API_KEY=your_mistral_api_key_here

# Reasoning routing target (OpenRouter Anthropic)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Direct OpenAI access for compatible tools/workflows
OPENAI_API_KEY=your_openai_api_key_here

# Deepgram Nova-3 STT and Aura-2 TTS
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Telegram bot long-polling token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Picovoice Porcupine wake-word access key
PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here

# LangSmith tracing for LangGraph agent observability
LANGSMITH_API_KEY=your_langsmith_api_key_here

# GitHub automation + repository operations
GITHUB_TOKEN=your_github_token_here
